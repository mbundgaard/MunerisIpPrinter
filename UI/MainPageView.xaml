<UserControl x:Class="MunerisIpPrinter.UI.MainPageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="#040D1A">
        <Image Source="/assets/muneris-bg.png" Stretch="Uniform" MaxWidth="400"
               HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20"
               RenderOptions.BitmapScalingMode="HighQuality"/>
        <Button Content="&#xE713;" Style="{StaticResource CopyButtonStyle}"
                FontFamily="Segoe MDL2 Assets" FontSize="15" Padding="9,7"
                ToolTip="Settings"
                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Margin="0,0,16,16"
                Click="Settings_Click"/>
    </Grid>
</UserControl>
