<Window x:Class="MunerisIpPrinter.UI.ConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Muneris IP Printer"
        Icon="/assets/app.ico"
        SizeToContent="Height"
        Width="400"
        MinHeight="160"
        Background="#040D1A"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <DockPanel Margin="22,20,22,18">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button x:Name="CancelButton" Padding="18,6" Margin="0,0,8,0"
                    Style="{StaticResource CopyButtonStyle}"
                    Click="Cancel_Click" IsCancel="True"/>
            <Button x:Name="ConfirmButton" Padding="18,6"
                    Style="{StaticResource CopyButtonStyle}"
                    Click="Confirm_Click" IsDefault="True"/>
        </StackPanel>

        <TextBlock x:Name="TitleText"
                   FontFamily="Segoe UI" FontWeight="SemiBold" FontSize="15"
                   Foreground="#E0E5EE" Margin="0,0,0,8"
                   DockPanel.Dock="Top"/>
        <TextBlock x:Name="MessageText"
                   FontFamily="Segoe UI" FontSize="13"
                   Foreground="#C8D0DC" TextWrapping="Wrap"
                   VerticalAlignment="Top"/>
    </DockPanel>
</Window>
