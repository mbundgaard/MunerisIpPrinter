<Window x:Class="MunerisIpPrinter.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Muneris IP Printer"
        Icon="/assets/app.ico"
        Height="720" Width="720"
        MinHeight="400" MinWidth="500"
        Background="#040D1A">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="SidebarColumn"
                              Width="200"
                              MinWidth="140" MaxWidth="480"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- left sidebar: printer list on top, Reset/Settings docked to the bottom -->
        <Border x:Name="SidebarBorder" Grid.Column="0"
                Background="#08111F"
                BorderBrush="#152639" BorderThickness="0,0,1,0">
            <DockPanel>
                <Border DockPanel.Dock="Top"
                        BorderBrush="#152639" BorderThickness="0,0,0,1"
                        Padding="12,8,12,8">
                    <TextBlock Text="Printers &#x00B7; port 9100"
                               Foreground="#7C8696"
                               FontFamily="Segoe UI" FontSize="11"
                               FontWeight="SemiBold"/>
                </Border>
                <Border DockPanel.Dock="Bottom"
                        BorderBrush="#152639" BorderThickness="0,1,0,0"
                        Padding="10,6,8,6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="MenuButton" Grid.Column="0" Content="&#xE700;"
                                Style="{StaticResource SubtleIconButtonStyle}"
                                FontFamily="Segoe MDL2 Assets" FontSize="14"
                                ToolTip="Menu"
                                Click="MenuButton_Click"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal"
                                    HorizontalAlignment="Right" VerticalAlignment="Center">
                            <TextBlock x:Name="UpdateLink" Visibility="Collapsed"
                                       Cursor="Hand" Foreground="#3A6FB8"
                                       FontFamily="Segoe UI" FontSize="11"
                                       FontWeight="SemiBold"
                                       Margin="0,0,8,0"
                                       MouseLeftButtonUp="UpdateLink_Click"/>
                            <TextBlock x:Name="VersionLabel"
                                       Foreground="#606B7A"
                                       FontFamily="Segoe UI" FontSize="11"/>
                        </StackPanel>
                    </Grid>
                </Border>
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl x:Name="Sidebar" Padding="6"/>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- drag handle between sidebar and detail. Transparent so the visible separator is
             the sidebar Border's 1px right edge; we keep a 4px hit zone for easy grabbing. -->
        <GridSplitter Grid.Column="1" Width="4"
                      HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                      Background="Transparent"
                      ShowsPreview="False"
                      ResizeBehavior="PreviousAndNext"
                      ResizeDirection="Columns"/>

        <!-- detail: every PrinterView is parented here, only the active one is visible -->
        <Grid x:Name="DetailHost" Grid.Column="2" Background="#040D1A"/>
    </Grid>
</Window>
