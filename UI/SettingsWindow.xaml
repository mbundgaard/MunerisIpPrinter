<Window x:Class="MunerisIpPrinter.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Width="460" Height="480"
        Background="#040D1A"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <DockPanel Margin="18">
        <TextBlock DockPanel.Dock="Top" Text="Printers"
                   Foreground="#E0E5EE" FontFamily="Segoe UI"
                   FontSize="15" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <TextBlock DockPanel.Dock="Top"
                   Text="Each printer gets its own tab. Point each POS printer record at the address shown (port 9100). Changes apply after a restart."
                   Foreground="#7C8696" FontFamily="Segoe UI" FontSize="11"
                   Margin="0,0,0,12" TextWrapping="Wrap"/>

        <Grid DockPanel.Dock="Bottom" Margin="0,12,0,0">
            <Button x:Name="AddButton" Content="+ Add printer" Click="Add_Click"
                    Style="{StaticResource CopyButtonStyle}"
                    HorizontalAlignment="Left"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" Click="Cancel_Click"
                        Style="{StaticResource CopyButtonStyle}" Margin="0,0,8,0"/>
                <Button Content="Save" Click="Save_Click"
                        Style="{StaticResource CopyButtonStyle}"/>
            </StackPanel>
        </Grid>

        <Border DockPanel.Dock="Bottom" BorderBrush="#152639" BorderThickness="0,1,0,0"
                Margin="0,12,0,0" Padding="0,12,0,0">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="Keep the last" VerticalAlignment="Center"
                               Foreground="#E0E5EE" FontFamily="Segoe UI" FontSize="12"/>
                    <TextBox x:Name="HistoryCountBox" Width="44" Margin="8,0,8,0"
                             Style="{StaticResource DarkTextBoxStyle}"
                             HorizontalContentAlignment="Center" MaxLength="3"/>
                    <TextBlock Text="prints per printer" VerticalAlignment="Center"
                               Foreground="#E0E5EE" FontFamily="Segoe UI" FontSize="12"/>
                </StackPanel>
                <CheckBox x:Name="LoggingCheck"
                          Content="Enable logging — save all messages and a debug log to a 'logs' folder"
                          Foreground="#E0E5EE" FontFamily="Segoe UI" FontSize="12"/>
            </StackPanel>
        </Border>

        <Grid DockPanel.Dock="Top" Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="118"/>
                <ColumnDefinition Width="34"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Name" Foreground="#7C8696"
                       FontFamily="Segoe UI" FontSize="11"/>
            <TextBlock Grid.Column="1" Text="Address (port 9100)" Foreground="#7C8696"
                       FontFamily="Segoe UI" FontSize="11" Margin="8,0,0,0"/>
        </Grid>

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <ItemsControl x:Name="PrinterList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="118"/>
                                <ColumnDefinition Width="34"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Style="{StaticResource DarkTextBoxStyle}"
                                     Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBox Grid.Column="1" Margin="8,0,0,0"
                                     Style="{StaticResource DarkTextBoxStyle}"
                                     IsReadOnly="True" Foreground="#9AA4B2"
                                     ToolTip="Auto-assigned — copy this into the POS printer record"
                                     Text="{Binding Address, Mode=OneWay}"/>
                            <Button Grid.Column="2" Content="&#xE74D;" Click="Remove_Click"
                                    Style="{StaticResource CopyButtonStyle}"
                                    FontFamily="Segoe MDL2 Assets" FontSize="13"
                                    Padding="0" Margin="6,0,0,0"
                                    ToolTip="Remove printer"/>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</Window>
