<Window x:Class="MunerisIpPrinter.UI.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Width="640" Height="470"
        Background="#040D1A"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Window.Resources>
        <!-- Left-nav item: transparent until hovered/selected, with a left accent bar when active. -->
        <Style x:Key="NavItemStyle" TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="#C8D0DC"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" Background="Transparent">
                            <Grid>
                                <Border x:Name="Accent" Width="3" HorizontalAlignment="Left"
                                        Background="#3A6FB8" Visibility="Collapsed"/>
                                <ContentPresenter VerticalAlignment="Center" Margin="16,9,12,9"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#0F2138"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#16294A"/>
                                <Setter TargetName="Accent" Property="Visibility" Value="Visible"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Minimal scrollbar for the printer list. -->
        <Style x:Key="ThinScrollBar" TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="5"/>
            <Setter Property="MinWidth" Value="5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="{TemplateBinding Background}">
                            <Track Name="PART_Track" IsDirectionReversed="True"
                                   ViewportSize="{TemplateBinding ViewportSize}"
                                   Maximum="{TemplateBinding Maximum}"
                                   Minimum="{TemplateBinding Minimum}"
                                   Value="{Binding Value, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#3A6FB8" CornerRadius="2"
                                                        Opacity="0.55" Margin="0,2"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left navigation -->
        <Border Grid.Column="0" Background="#081320" BorderBrush="#152639" BorderThickness="0,0,1,0">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="Settings" Foreground="#7C8696"
                           FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold"
                           Margin="16,16,0,10"/>
                <ListBox x:Name="NavList" Background="Transparent" BorderThickness="0"
                         SelectionChanged="Nav_SelectionChanged"
                         ItemContainerStyle="{StaticResource NavItemStyle}">
                    <ListBoxItem Content="Printers"/>
                    <ListBoxItem Content="General"/>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- Content -->
        <Grid Grid.Column="1" Margin="22,18,18,18">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ===== Printers section ===== -->
            <DockPanel x:Name="PrintersPanel" Grid.Row="0">
                <TextBlock DockPanel.Dock="Top" Text="Printers"
                           Foreground="#E0E5EE" FontFamily="Segoe UI"
                           FontSize="15" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <TextBlock DockPanel.Dock="Top"
                           Text="Each printer gets its own tab. Point each POS printer record at the address shown (port 9100). Changes apply after a restart."
                           Foreground="#7C8696" FontFamily="Segoe UI" FontSize="11"
                           Margin="0,0,0,12" TextWrapping="Wrap"/>

                <Button x:Name="AddButton" DockPanel.Dock="Bottom" Content="+ Add printer" Click="Add_Click"
                        Style="{StaticResource CopyButtonStyle}"
                        HorizontalAlignment="Left" Margin="0,10,0,0"/>

                <Grid DockPanel.Dock="Top" Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="118"/>
                        <ColumnDefinition Width="34"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Name" Foreground="#7C8696"
                               FontFamily="Segoe UI" FontSize="11"/>
                    <TextBlock Grid.Column="1" Text="Address (port 9100)" Foreground="#7C8696"
                               FontFamily="Segoe UI" FontSize="11" Margin="8,0,0,0"/>
                </Grid>

                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <ScrollViewer.Resources>
                        <Style TargetType="ScrollBar" BasedOn="{StaticResource ThinScrollBar}"/>
                    </ScrollViewer.Resources>
                    <ItemsControl x:Name="PrinterList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,3">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="118"/>
                                        <ColumnDefinition Width="34"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0"
                                             Style="{StaticResource DarkTextBoxStyle}"
                                             Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>
                                    <TextBox Grid.Column="1" Margin="8,0,0,0"
                                             Style="{StaticResource DarkTextBoxStyle}"
                                             IsReadOnly="True" Foreground="#9AA4B2"
                                             ToolTip="Auto-assigned — copy this into the POS printer record"
                                             Text="{Binding Address, Mode=OneWay}"/>
                                    <Button Grid.Column="2" Content="&#xE74D;" Click="Remove_Click"
                                            Style="{StaticResource CopyButtonStyle}"
                                            FontFamily="Segoe MDL2 Assets" FontSize="13"
                                            Padding="0" Margin="6,0,0,0"
                                            ToolTip="Remove printer"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>

            <!-- ===== General section ===== -->
            <StackPanel x:Name="GeneralPanel" Grid.Row="0" Visibility="Collapsed">
                <TextBlock Text="General" Foreground="#E0E5EE" FontFamily="Segoe UI"
                           FontSize="15" FontWeight="SemiBold" Margin="0,0,0,16"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="128"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Default code page"
                               VerticalAlignment="Center" Margin="0,0,0,4"
                               Foreground="#E0E5EE" FontFamily="Segoe UI" FontSize="12"/>
                    <ComboBox Grid.Row="0" Grid.Column="1" x:Name="CodePageCombo"
                              HorizontalAlignment="Stretch" Margin="0,0,0,4"
                              Style="{StaticResource DarkComboBoxStyle}"/>

                    <TextBlock Grid.Row="1" Grid.Column="1" TextWrapping="Wrap" Margin="0,0,0,16"
                               Text="Used when the received print data does not contain an explicit code page (ESC t n). Data that does specify one overrides this setting."
                               Foreground="#7C8696" FontFamily="Segoe UI" FontSize="11"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Receipt history"
                               VerticalAlignment="Center" Margin="0,0,0,14"
                               Foreground="#E0E5EE" FontFamily="Segoe UI" FontSize="12"/>
                    <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,14">
                        <TextBox x:Name="HistoryCountBox" Width="44"
                                 Style="{StaticResource DarkTextBoxStyle}"
                                 HorizontalContentAlignment="Center" MaxLength="3"/>
                        <TextBlock Text="prints kept per printer" VerticalAlignment="Center"
                                   Margin="8,0,0,0"
                                   Foreground="#E0E5EE" FontFamily="Segoe UI" FontSize="12"/>
                    </StackPanel>

                    <CheckBox Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" x:Name="LoggingCheck"
                              VerticalAlignment="Center"
                              Content="Save all messages and a debug log to a 'logs' folder"
                              Foreground="#E0E5EE" FontFamily="Segoe UI" FontSize="12"/>
                </Grid>
            </StackPanel>

            <!-- Shared action bar -->
            <StackPanel Grid.Row="1" Orientation="Horizontal"
                        HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button Content="Cancel" Click="Cancel_Click"
                        Style="{StaticResource CopyButtonStyle}" Margin="0,0,8,0"/>
                <Button Content="Save" Click="Save_Click"
                        Style="{StaticResource CopyButtonStyle}"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
