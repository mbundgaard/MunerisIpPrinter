<UserControl x:Class="MunerisIpPrinter.UI.PrinterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="#040D1A">
        <!-- Empty-state mark shown when no receipts have arrived for this printer. -->
        <StackPanel x:Name="EmptyHint"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Margin="20" Opacity="0.85">
            <TextBlock x:Name="EmptyTitleText" Text="Muneris" Foreground="#3A6FB8"
                       FontFamily="/assets/#Conthrax" FontSize="56"
                       HorizontalAlignment="Center"/>
            <Viewbox Stretch="Uniform"
                     Width="{Binding ElementName=EmptyTitleText, Path=ActualWidth}"
                     Margin="0,2,0,8">
                <TextBlock Text="Software Development &amp; Consulting"
                           Foreground="#8B97A8"
                           FontFamily="Segoe UI" FontSize="14"/>
            </Viewbox>
            <Border Height="1" Background="#244065"
                    Width="{Binding ElementName=EmptyTitleText, Path=ActualWidth}"
                    HorizontalAlignment="Center"/>
        </StackPanel>

        <ScrollViewer x:Name="ReceiptScroll"
                      VerticalScrollBarVisibility="Hidden"
                      HorizontalScrollBarVisibility="Disabled"
                      Visibility="Collapsed">
            <StackPanel x:Name="ReceiptStack" Margin="0,20,0,20"/>
        </ScrollViewer>
    </Grid>
</UserControl>
